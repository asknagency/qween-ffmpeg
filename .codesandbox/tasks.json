{
  "tasks": {
    "install": {
      "name": "Install dependencies",
      "command": "npm install && cd apps/web && npm install && cd ../api && pip install -r requirements.txt --quiet && python -m playwright install chromium --with-deps",
      "runAtStart": true
    },
    "api": {
      "name": "FastAPI (port 8000)",
      "command": "cd apps/api && uvicorn main:app --reload --host 0.0.0.0 --port 8000",
      "runAtStart": true,
      "preview": { "port": 8000, "label": "API" }
    },
    "web": {
      "name": "Next.js (port 3000)",
      "command": "cd apps/web && npm run dev",
      "runAtStart": true,
      "preview": { "port": 3000, "label": "App" }
    }
  }
}

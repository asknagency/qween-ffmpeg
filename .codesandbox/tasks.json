{
  "$schema": "https://schemas.codesandbox.io/configuration/tasks.json",
  "setupTasks": [
    {
      "name": "Install ffmpeg",
      "command": "sudo apt-get update -qq && sudo apt-get install -y ffmpeg"
    },
    {
      "name": "Install pnpm",
      "command": "npm install -g pnpm@9.1.0"
    },
    {
      "name": "Install Node deps (web + app)",
      "command": "pnpm install"
    },
    {
      "name": "Install Python deps",
      "command": "cd apps/api && pip install -r requirements.txt"
    },
    {
      "name": "Install Playwright browser",
      "command": "cd apps/api && python -m playwright install chromium --with-deps"
    },
    {
      "name": "Create .env",
      "command": "[ -f .env ] || cp .env.example .env"
    }
  ],
  "tasks": {
    "dev:app": {
      "name": "\u25b6 Renderer (Node :3000)",
      "command": "cd apps/app && node server.js",
      "runAtStart": true,
      "preview": {
        "port": 3000
      }
    },
    "dev:api": {
      "name": "\u25b6 API (FastAPI :8000)",
      "command": "cd apps/api && uvicorn main:app --reload --port 8000 --host 0.0.0.0",
      "runAtStart": true,
      "preview": {
        "port": 8000
      }
    },
    "dev:web": {
      "name": "\u25b6 Web (Next.js :5000)",
      "command": "cd apps/web && pnpm dev",
      "runAtStart": true,
      "preview": {
        "port": 5000
      }
    },
    "health": {
      "name": "\u2713 Health check",
      "command": "curl -s http://localhost:8000/health | python3 -m json.tool"
    },
    "typecheck": {
      "name": "\u2713 TypeScript check",
      "command": "cd apps/web && pnpm exec tsc --noEmit"
    }
  }
}
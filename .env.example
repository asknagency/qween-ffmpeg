# ── API (FastAPI, port 8000) ──────────────────────────────────────────────────
PORT=8000
CORS_ORIGINS=*

# ── App (Node.js renderer, port 3000) ────────────────────────────────────────
RENDERER_PORT=3000

# ── Web (Next.js, port 3001) ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
